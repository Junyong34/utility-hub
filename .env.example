# Site Configuration
# 프로덕션에서는 실제 도메인으로 변경하세요
NEXT_PUBLIC_SITE_URL=https://www.zento.kr

# GA4 Analytics Data API (Server-only)
GA4_PROPERTY_ID=
GA4_CLIENT_EMAIL=
GA4_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GA4_BASELINE_DATE=2024-01-01
GA4_TIMEZONE=Asia/Seoul

# Private finance storage (Server-only, optional)
# 테스트나 별도 런타임에서만 절대 경로로 재정의하세요.
# FINANCE_SNAPSHOTS_PATH=/absolute/path/to/finance-snapshots.json
